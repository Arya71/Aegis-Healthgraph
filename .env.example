# ============================================================================
# Aegis HealthGraph — environment configuration
# Copy to `.env`. Everything works with NO config (replay mode).
# ============================================================================

# Memory backend: "replay" (default, zero-config) or "cloud" (live Cognee).
AEGIS_MEMORY_MODE=replay

# ── Cognee API (live memory) ────────────────────────────────────────────────
# 1) Get an API key + instance URL at https://platform.cognee.ai
#    (free Developer plan, code COGNEE-35) — or point at a self-hosted server.
# 2) Fill the two values below and set AEGIS_MEMORY_MODE=cloud.
# 3) Seed memory:  python scripts/seed_cognee.py
COGNEE_API_URL=
COGNEE_API_KEY=
COGNEE_TIMEOUT=30

# Frontend → backend base URL (leave as /api to use the Vite dev proxy).
# VITE_API_BASE=/api

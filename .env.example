# ============================================================================
# Aegis HealthGraph - environment configuration
# Copy to `.env`. Everything works with NO config (replay mode).
# ============================================================================

# Memory backend: "replay" (default, zero-config) or "cloud" (real Cognee).
AEGIS_MEMORY_MODE=replay

# --- Cognee Cloud (live memory) --------------------------------------------
# 1) Sign in at https://platform.cognee.ai  (free Developer plan, code COGNEE-35)
# 2) Create an API key and copy your instance URL.
# 3) Set the two vars below and AEGIS_MEMORY_MODE=cloud.
# 4) Seed memory:  python scripts/seed_cognee.py
#
# COGNEE_API_URL=https://<your-instance>.cognee.ai
# COGNEE_API_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxx
# COGNEE_TIMEOUT=30
#
# (Self-hosted Cognee works too — point COGNEE_API_URL at http://localhost:8000.)

# Frontend -> backend base URL (leave as /api to use the Vite dev proxy)
# VITE_API_BASE=/api

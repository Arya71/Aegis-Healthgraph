# =============================================================================
# Aegis HealthGraph — environment configuration
# Copy this file to .env  (project root, same level as backend/ and frontend/)
# Everything works with NO config (replay mode, mock data).
# =============================================================================

# ── Memory mode ───────────────────────────────────────────────────────────────
# "replay" = fully offline demo, zero setup (default)
# "cloud"  = connects to real Cognee for live AI memory (requires keys below)
AEGIS_MEMORY_MODE=replay

# ── Gemini API key (for OmniGest document + image extraction) ─────────────────
# Get yours free at https://aistudio.google.com/app/apikey
# Without this, OmniGest uses deterministic mock extraction (still works for demo)
GEMINI_API_KEY=

# Optionally pin to a specific Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ── Cognee AI memory (only needed for AEGIS_MEMORY_MODE=cloud) ───────────────
#
# Option A — Cognee Cloud (no Docker needed):
#   1. Sign up free at https://platform.cognee.ai  (code COGNEE-35 for credits)
#   2. Create an API key, paste it below
#   3. Set COGNEE_API_URL to your instance URL
#
# Option B — Self-hosted (free, needs Docker):
#   1. Follow AEGIS_SETUP_GUIDE.md Part B
#   2. Leave COGNEE_API_KEY as "local-dev-key"
#   3. Leave COGNEE_API_URL as http://localhost:8000
#
COGNEE_API_URL=http://localhost:8000
COGNEE_API_KEY=local-dev-key

# How long to wait for Cognee responses (seconds).
# Increase to 120 if cognify is slow on large documents.
COGNEE_TIMEOUT=60
